<?xml version="1.0" encoding="utf-8"?>
<!-- item_tarea.xml - Layout modificado con CheckBox para completar tarea -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent"
    android:layout_marginBottom="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_mint"
        android:padding="16dp">

        <!-- CheckBox para marcar tarea completada. -->
        <CheckBox
            android:id="@+id/checkboxCompletar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:buttonTint="@color/mint_dark"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Título (ahora empieza después del checkbox) -->
        <TextView
            android:id="@+id/tvTareaTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Título Tarea"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/checkboxCompletar"
            app:layout_constraintEnd_toStartOf="@+id/cardArrow"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Fecha -->
        <TextView
            android:id="@+id/tvTareaFecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Fecha y hora"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            app:layout_constraintEnd_toEndOf="@+id/tvTareaTitulo"
            app:layout_constraintTop_toBottomOf="@id/tvTareaTitulo"
            app:layout_constraintStart_toEndOf="@id/checkboxCompletar"/>

        <!-- Botón de expandir/contraer -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardArrow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#00897B"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgArrowIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_down"
                android:layout_gravity="center"
                app:tint="@color/white"
                android:contentDescription="Expandir/Contraer"/>
        </androidx.cardview.widget.CardView>

        <!-- Sección expandible con detalles -->
        <LinearLayout
            android:id="@+id/layoutDetallesHidden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvTareaFecha">

            <!-- Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvDescripcionBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detalles de la tarea..."
                android:textColor="#555"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"/>

            <!-- Ubicación -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Ubicación"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvUbicacionBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sin ubicación"
                android:textColor="#555"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- Botón Editar -->
                <ImageView
                    android:id="@+id/btnEditar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit_outline"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Editar"
                    app:tint="#00897B"/>

                <!-- Botón Compartir -->
                <ImageView
                    android:id="@+id/btnCompartir"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_share_outline"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Compartir"
                    android:layout_marginStart="8dp"
                    app:tint="#00897B"/>

                <!-- Botón Menú (3 puntos) -->
                <ImageView
                    android:id="@+id/btnMenuOpciones"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_more_options"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Más opciones"
                    android:layout_marginStart="8dp"
                    app:tint="#00897B"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>