<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml - Manifest modificado con SplashActivity como pantalla inicial -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos necesarios para Bluetooth (funcionalidad compartir tareas) -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_taskflow_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_taskflow_logo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaskFlow"
        tools:targetApi="31">

        <!-- ================================================================= -->
        <!-- SPLASH SCREEN - Actividad inicial (LAUNCHER)                    -->
        <!-- Se muestra primero cuando se abre la app                         -->
        <!-- ================================================================= -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ================================================================= -->
        <!-- MAIN ACTIVITY - Actividad principal                              -->
        <!-- Ya NO es LAUNCHER, se accede desde SplashActivity                -->
        <!-- ================================================================= -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.TaskFlow" />

        <!-- ================================================================= -->
        <!-- OTRAS ACTIVIDADES                                                -->
        <!-- ================================================================= -->

        <!-- Actividad para crear/editar tareas -->
        <activity
            android:name=".CrearTareaActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.TaskFlow" />

        <!-- Actividad del calendario -->
        <activity
            android:name=".CalendarioActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.TaskFlow" />

    </application>
</manifest>